# mall-demo backend
MALL_DB_URL=jdbc:mysql://127.0.0.1:3306/mall_demo?useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
MALL_DB_USERNAME=root
MALL_DB_PASSWORD=root

# Payment gateway (legacy single-merchant config, still supported for backward compatibility)
PAYMENT_GATEWAY_BASE_URL=http://localhost:8080
# PAYMENT_API_KEY=replace_with_your_api_key
# PAYMENT_API_SECRET=replace_with_your_api_secret
PAYMENT_CHECKOUT_BASE_URL=http://localhost:5173

# Multi-tenant merchant configuration (recommended)
# Format: MALL_DEMO_MERCHANTS_{id}={apiKey}:{apiSecret}:{name}
MALL_DEMO_MERCHANTS_MERCHANT_A=your_api_key_a:your_api_secret_a:Merchant A
MALL_DEMO_MERCHANTS_MERCHANT_B=your_api_key_b:your_api_secret_b:Merchant B

MALL_WEBHOOK_SECRET=replace_with_webhook_secret
MALL_FRONTEND_RESULT_BASE_URL=http://localhost:5174/result
MALL_DEMO_CHAIN=ANVIL
MALL_DEMO_ASSET=USDT
